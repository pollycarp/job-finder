# Copy this file to .env and fill in your values for local development
# Never commit the .env file — it contains secrets

GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_CREDENTIALS_JSON=path/to/your/credentials.json

# Green API — WhatsApp notifications (green-api.com)
GREEN_API_INSTANCE_ID=your_instance_id
GREEN_API_TOKEN=your_api_token
WHATSAPP_GROUP_CHAT_ID=your_group_chat_id@g.us
